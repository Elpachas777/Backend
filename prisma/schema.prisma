generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Usuario {
  id_usuario    Int            @id @default(autoincrement())
  nombres       String
  apellido      String
  administrador Administrador?
  alumno        Alumno?
  docente       Docente?
}

model Administrador {
  id_admin    Int     @id @default(autoincrement())
  correo      String  @unique
  contraseña String
  bloqueado   Boolean @default(false)
  usuarioId   Int     @unique
  usuario     Usuario @relation(fields: [usuarioId], references: [id_usuario], onDelete: Cascade)
}

model Docente {
  id_docente  Int     @id @default(autoincrement())
  correo      String  @unique
  contraseña String
  id_escuela  Int
  autorizado  Boolean @default(false)
  bloqueado   Boolean @default(false)
  usuarioId   Int     @unique

  usuario    Usuario     @relation(fields: [usuarioId], references: [id_usuario], onDelete: Cascade)
  escuela    Escuela     @relation(fields: [id_escuela], references: [id_escuela])
  ejercicios Ejercicio[]
  grupos     Grupo[]
}

model Escuela {
  id_escuela        Int       @id @default(autoincrement())
  nombre            String
  ubicacion         String?
  director          String?
  contacto          String?
  contado_adicional String?
  docentes          Docente[]
}

model Alumno {
  id_alumno  Int         @id @default(autoincrement())
  id_grupo   Int?
  usuarioId  Int         @unique
  grupo      Grupo?      @relation(fields: [id_grupo], references: [id_grupo])
  usuario    Usuario     @relation(fields: [usuarioId], references: [id_usuario], onDelete: Cascade)
  respuestas Respuesta[]

  @@index([id_grupo], map: "Alumno_id_grupo_fkey")
}

model Grupo {
  id_grupo     Int         @id @default(autoincrement())
  nombre_grupo String
  id_docente   Int
  turno        String
  alumnos      Alumno[]
  ejercicios   Ejercicio[]
  docente      Docente     @relation(fields: [id_docente], references: [id_docente])

  @@index([id_docente], map: "Grupo_id_docente_fkey")
}

model Ejercicio {
  id_ejercicio Int      @id @default(autoincrement())
  fecha_inicio DateTime
  fecha_final  DateTime
  id_grupo     Int?
  id_docente   Int
  id_tipo      Int
  titulo       String
  contenido    Json

  docente    Docente       @relation(fields: [id_docente], references: [id_docente])
  grupo      Grupo?        @relation(fields: [id_grupo], references: [id_grupo])
  tipo       TipoEjercicio @relation(fields: [id_tipo], references: [id_tipo])
  respuestas Respuesta[]

  @@index([id_docente], map: "Ejercicio_id_docente_fkey")
  @@index([id_grupo], map: "Ejercicio_id_grupo_fkey")
  @@index([id_tipo], map: "Ejercicio_id_tipo_fkey")
}

model TipoEjercicio {
  id_tipo    Int         @id @default(autoincrement())
  nombre     String      @unique
  ejercicios Ejercicio[]
}

model Respuesta {
  id_respuesta Int       @id @default(autoincrement())
  trazo        String
  puntaje      Int
  id_alumno    Int
  id_ejercicio Int
  alumno       Alumno    @relation(fields: [id_alumno], references: [id_alumno])
  ejercicio    Ejercicio @relation(fields: [id_ejercicio], references: [id_ejercicio])

  @@index([id_alumno], map: "Respuesta_id_alumno_fkey")
  @@index([id_ejercicio], map: "Respuesta_id_ejercicio_fkey")
}
